# ============================================================
# L Board — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# ---------------------------
# Supabase (obrigatório)
# Encontre em: https://supabase.com/dashboard/project/_/settings/api
# ---------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------
# URL da aplicação (obrigatório)
# Em desenvolvimento: http://localhost:3000
# Em produção: https://seu-dominio.vercel.app
# ---------------------------
NEXT_PUBLIC_APP_URL=

# ---------------------------
# Criptografia AES-256-GCM (obrigatório)
# Gere com: openssl rand -hex 32
# ---------------------------
ENCRYPTION_KEY=

# ---------------------------
# OpenAI (opcional — necessário para a Assistente de IA)
# Encontre em: https://platform.openai.com/api-keys
# ---------------------------
OPENAI_API_KEY=

# ---------------------------
# Resend (opcional — necessário para envio de e-mails de convite)
# Encontre em: https://resend.com/api-keys
# ---------------------------
RESEND_API_KEY=
RESEND_FROM=L Board <noreply@seudominio.com>

# ---------------------------
# Sentry (opcional — monitoramento de erros em produção)
# Encontre em: https://sentry.io
# ---------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
